</product-info>

{%- if template.suffix == 'card' or has_custom_options -%}
  <script id="ProductVariantsDataCard" type="application/json">
    {{ product.variants | json }}
  </script>
  <script id="ProductOptionsDataCard" type="application/json">
    {{ product.options | json }}
  </script>
  <script>
    (function() {
      const initCardTemplateLogic = () => {
        console.log("initCardTemplateLogic: Start execution");
        try {
          const sectionContainer = document.getElementById('MainProduct-{{ section.id }}');
          if (!sectionContainer) {
            console.warn("initCardTemplateLogic: sectionContainer (MainProduct-{{ section.id }}) not found");
            return;
          }
          console.log("initCardTemplateLogic: found sectionContainer", sectionContainer);

          const currentQtyBtn = sectionContainer.querySelector('.pdp-qty-btn.active');
          let currentQty = currentQtyBtn ? (parseInt(currentQtyBtn.dataset.qty) || 100) : 100;
          console.log("initCardTemplateLogic: initial currentQty =", currentQty);

          const customInputs = sectionContainer.querySelectorAll('#qty-custom-input');
          const hiddenQtys = sectionContainer.querySelectorAll('#qty-input-hidden');
          const qtyCustomContainers = sectionContainer.querySelectorAll('#qty-custom-container');

          if (currentQtyBtn && currentQtyBtn.dataset.qty === 'custom' && customInputs.length > 0) {
            currentQty = parseInt(customInputs[0].value) || 100;
          }

          const variantsDataEl = document.getElementById('ProductVariantsDataCard');
          if (!variantsDataEl) {
            console.warn("initCardTemplateLogic: variantsDataEl (ProductVariantsDataCard) not found");
            return;
          }
          
          let variants = [];
          try {
            variants = JSON.parse(variantsDataEl.textContent) || [];
          } catch (jsonErr) {
            console.error("initCardTemplateLogic: JSON parse failed for variants data:", jsonErr);
            return;
          }
          console.log("initCardTemplateLogic: loaded variants =", variants);

          const optionsDataEl = document.getElementById('ProductOptionsDataCard');
          let productOptions = [];
          if (optionsDataEl) {
            try {
              productOptions = JSON.parse(optionsDataEl.textContent) || [];
            } catch (err) {
              console.error("initCardTemplateLogic: options parsing failed", err);
            }
          }

          const variantIdInput = sectionContainer.querySelector('input[name="id"]');
          const activeVariantId = variantIdInput ? parseInt(variantIdInput.value) : {{ product.selected_or_first_available_variant.id | json }};
          console.log("initCardTemplateLogic: activeVariantId =", activeVariantId);

          let activeVariant = variants.find(v => String(v.id) === String(activeVariantId));
          if (!activeVariant && variants.length > 0) {
            activeVariant = variants[0];
            console.log("initCardTemplateLogic: fallback to first variant", activeVariant);
          }
          
          if (!activeVariant) {
            console.warn("initCardTemplateLogic: no active variant found");
            return;
          }

          const basePrice = activeVariant.price;
          const minQty = {{ section.settings.min_qty | default: 100 | plus: 0 }};
          const taxRate = {{ section.settings.tax_rate | default: 5 | plus: 0 }};
          const discountScheduleString = {{ section.settings.qty_discount_schedule | default: "100:0" | json }};
          
          const discountSchedule = [];
          if (discountScheduleString) {
            discountScheduleString.split(',').forEach(item => {
              const parts = item.trim().split(':');
              if (parts.length === 2) {
                discountSchedule.push({
                  qty: parseInt(parts[0]),
                  discount: parseFloat(parts[1])
                });
              }
            });
            discountSchedule.sort((a, b) => b.qty - a.qty);
          }

          function getDiscountMultiplier(qty) {
            let discountPercent = 0;
            for (let item of discountSchedule) {
              if (qty >= item.qty) {
                discountPercent = item.discount;
                break;
              }
            }
            return 1 - (discountPercent / 100);
          }

          function formatMoney(cents) {
            const formatString = {{ shop.money_with_currency_format | json }};
            const val = (cents / 100).toFixed(2);
            let formattedVal = parseFloat(val).toLocaleString('en-IN', {
              minimumFractionDigits: 2,
              maximumFractionDigits: 2
            });
            return formatString.replace(/\{\{\s*amount\s*\}\}/g, formattedVal).replace(/\{\{\s*amount_with_comma_separator\s*\}\}/g, formattedVal);
          }

          const updatePricing = () => {
            const currentQtyBtn = sectionContainer.querySelector('.pdp-qty-btn.active');
            let currentQty = currentQtyBtn ? (parseInt(currentQtyBtn.dataset.qty) || 100) : 100;
            if (currentQtyBtn && currentQtyBtn.dataset.qty === 'custom' && customInputs.length > 0) {
              currentQty = parseInt(customInputs[0].value) || 100;
            }

            const variantIdInput = sectionContainer.querySelector('input[name="id"]');
            const activeVariantId = variantIdInput ? parseInt(variantIdInput.value) : null;
            const activeVariant = variants.find(v => String(v.id) === String(activeVariantId)) || variants[0];
            const basePrice = activeVariant ? activeVariant.price : 0;

            console.log("updatePricing: currentQty =", currentQty, "basePrice =", basePrice);
            const discountMult = getDiscountMultiplier(currentQty);
            
            let finishingUpcharges = 0;
            const activeFinishes = [];
            
            const uniqueActiveFinishes = new Set();
            sectionContainer.querySelectorAll('.pdp-finishing-btn.active').forEach(btn => {
              uniqueActiveFinishes.add(btn.dataset.value);
            });
            
            uniqueActiveFinishes.forEach(val => {
              const btn = Array.from(sectionContainer.querySelectorAll('.pdp-finishing-btn')).find(b => b.dataset.value === val);
              if (btn) {
                const upchargeVal = parseFloat(btn.dataset.upcharge) || 0;
                console.log(`updatePricing: finish = ${val}, upcharge = ${upchargeVal}`);
                finishingUpcharges += upchargeVal * 100;
                activeFinishes.push(val);
              }
            });
            console.log("updatePricing: finishingUpcharges =", finishingUpcharges, "activeFinishes =", activeFinishes);
            
            const propFinishings = sectionContainer.querySelectorAll('#prop-finishing');
            propFinishings.forEach(el => el.value = activeFinishes.join(', '));

            const unitPrice = Math.round(basePrice * discountMult) + finishingUpcharges;
            const totalPrice = unitPrice * currentQty;

            const priceTotals = sectionContainer.querySelectorAll('#PdpPriceTotal');
            const priceBreakdowns = sectionContainer.querySelectorAll('#PdpPriceBreakdown');

            priceTotals.forEach(el => el.textContent = formatMoney(totalPrice));
            priceBreakdowns.forEach(el => el.textContent = `For ${currentQty} Qty (${formatMoney(unitPrice)} / piece)`);
            
            hiddenQtys.forEach(el => el.value = currentQty);

            if (activeVariant) {
              let shapeVal = "";
              let printVal = "";
              let materialVal = "";

              productOptions.forEach((optName, idx) => {
                const optKey = 'option' + (idx + 1);
                const optVal = activeVariant[optKey] || "";
                const downcaseName = optName.toLowerCase();
                
                if (downcaseName.includes('shape')) {
                  shapeVal = optVal;
                } else if (downcaseName.includes('print') || downcaseName.includes('side')) {
                  printVal = optVal;
                } else if (downcaseName.includes('material')) {
                  materialVal = optVal;
                }
              });

              const propShapes = sectionContainer.querySelectorAll('#prop-shape');
              const propPrintTypes = sectionContainer.querySelectorAll('#prop-print-type');
              const propMaterials = sectionContainer.querySelectorAll('#prop-material');

              propShapes.forEach(el => el.value = shapeVal);
              propPrintTypes.forEach(el => el.value = printVal);
              propMaterials.forEach(el => el.value = materialVal);
            }
          };

          if (!sectionContainer.dataset.listenersBound) {
            sectionContainer.dataset.listenersBound = 'true';
            console.log("initCardTemplateLogic: Binding listeners to sectionContainer");

            // Event Delegation for click events
            sectionContainer.addEventListener('click', (e) => {
              // 1. pdp-shape-card click
              const shapeCard = e.target.closest('.pdp-shape-card');
              if (shapeCard) {
                console.log("Delegated click: shape card", shapeCard.dataset.value);
                const radio = shapeCard.querySelector('input[type="radio"]');
                if (radio && !radio.checked) {
                  radio.checked = true;
                  radio.dispatchEvent(new Event('change', { bubbles: true }));
                }
                return;
              }

              // 2. pdp-print-btn click
              const printBtn = e.target.closest('.pdp-print-btn');
              if (printBtn) {
                console.log("Delegated click: print button", printBtn.dataset.value);
                const radio = printBtn.querySelector('input[type="radio"]');
                if (radio && !radio.checked) {
                  radio.checked = true;
                  radio.dispatchEvent(new Event('change', { bubbles: true }));
                }
                return;
              }

              // 3. pdp-material-trigger click
              const materialTrigger = e.target.closest('.pdp-material-trigger');
              if (materialTrigger) {
                e.stopPropagation();
                console.log("Delegated click: material trigger");
                const selector = materialTrigger.closest('.pdp-material-selector');
                if (selector) selector.classList.toggle('open');
                return;
              }

              // 4. pdp-material-option click
              const materialOption = e.target.closest('.pdp-material-option');
              if (materialOption) {
                e.stopPropagation();
                console.log("Delegated click: material option", materialOption.dataset.optionValue);
                const selector = materialOption.closest('.pdp-material-selector');
                if (selector) {
                  const val = materialOption.dataset.optionValue;
                  const select = selector.querySelector('select');
                  if (select) {
                    select.value = val;
                    select.dispatchEvent(new Event('change', { bubbles: true }));
                  }
                  selector.classList.remove('open');
                }
                return;
              }

              // 5. pdp-qty-btn click
              const qtyBtn = e.target.closest('.pdp-qty-btn');
              if (qtyBtn) {
                console.log("Delegated click: quantity button", qtyBtn.dataset.qty);
                const qtyVal = qtyBtn.dataset.qty;
                
                sectionContainer.querySelectorAll('.pdp-qty-btn').forEach(b => {
                  b.classList.toggle('active', b.dataset.qty === qtyVal);
                });
                
                if (qtyVal === 'custom') {
                  qtyCustomContainers.forEach(el => el.classList.add('active'));
                  customInputs.forEach(el => {
                    let val = parseInt(el.value) || minQty;
                    if (val < minQty) {
                      val = minQty;
                      el.value = minQty;
                    }
                  });
                } else {
                  qtyCustomContainers.forEach(el => el.classList.remove('active'));
                }
                updatePricing();
                return;
              }

              // 6. pdp-finishing-btn click
              const finishingBtn = e.target.closest('.pdp-finishing-btn');
              if (finishingBtn) {
                console.log("Delegated click: finishing button", finishingBtn.dataset.value);
                const val = finishingBtn.dataset.value;
                
                const wasActive = finishingBtn.classList.contains('active');
                
                if (!wasActive) {
                  sectionContainer.querySelectorAll('.pdp-finishing-btn').forEach(b => {
                    if (b.dataset.value !== val) {
                      b.classList.remove('active');
                    }
                  });
                }
                
                sectionContainer.querySelectorAll('.pdp-finishing-btn').forEach(b => {
                  if (b.dataset.value === val) {
                    b.classList.toggle('active', !wasActive);
                  }
                });
                
                updatePricing();
                return;
              }
            });

            // Close material dropdown when clicking outside
            document.addEventListener('click', (e) => {
              if (!e.target.closest('.pdp-material-selector')) {
                sectionContainer.querySelectorAll('.pdp-material-selector').forEach(el => {
                  el.classList.remove('open');
                });
              }
            });

            // Custom qty inputs events
            if (customInputs.length > 0) {
              customInputs.forEach(input => {
                input.addEventListener('input', () => {
                  let val = parseInt(input.value);
                  customInputs.forEach(other => {
                    if (other !== input) other.value = input.value;
                  });
                  updatePricing();
                });

                input.addEventListener('blur', () => {
                  let val = parseInt(input.value);
                  if (isNaN(val) || val < minQty) {
                    customInputs.forEach(other => {
                      other.value = minQty;
                    });
                  }
                  updatePricing();
                });
              });
            }

            // File upload events
            const fileInput = sectionContainer.querySelector('#pdp-file-input');
            const uploadLabel = sectionContainer.querySelector('.pdp-upload-label');
            const filenameDisplay = sectionContainer.querySelector('#pdp-upload-filename-display');
            const filenameText = sectionContainer.querySelector('#pdp-upload-filename-text');
            const removeFileBtn = sectionContainer.querySelector('#pdp-upload-remove');

            if (uploadLabel && fileInput) {
              uploadLabel.addEventListener('click', () => {
                fileInput.click();
              });

              fileInput.addEventListener('change', () => {
                if (fileInput.files.length > 0) {
                  const file = fileInput.files[0];
                  if (filenameText) filenameText.textContent = file.name;
                  if (filenameDisplay) filenameDisplay.style.display = 'flex';
                } else {
                  if (filenameDisplay) filenameDisplay.style.display = 'none';
                }
              });

              if (removeFileBtn) {
                removeFileBtn.addEventListener('click', (e) => {
                  e.stopPropagation();
                  fileInput.value = '';
                  if (filenameDisplay) filenameDisplay.style.display = 'none';
                });
              }
            }
          }

          if (typeof PUB_SUB_EVENTS !== 'undefined' && typeof subscribe !== 'undefined') {
            if (window.variantChangeUnsubscribe) {
              window.variantChangeUnsubscribe();
            }
            window.variantChangeUnsubscribe = subscribe(PUB_SUB_EVENTS.variantChange, (event) => {
              updatePricing();
            });
          }

          updatePricing();
          console.log("initCardTemplateLogic: End execution successfully");
        } catch (err) {
          console.error("initCardTemplateLogic: Unhandled error during initialization:", err);
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCardTemplateLogic);
      } else {
        initCardTemplateLogic();
      }
      
      document.addEventListener('product-info:loaded', () => {
        initCardTemplateLogic();
      });
    })();
  </script>
